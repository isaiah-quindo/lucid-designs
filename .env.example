# Resend — used by /api/contact to deliver project briefs
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# The "from" address shown in the email. Must be on a verified domain in Resend.
# Format: "Lucid Designs <hello@luciddesigns.com.au>"
# Until your domain is verified, you can use the sandbox sender:
# RESEND_FROM="Lucid Designs <onboarding@resend.dev>"
RESEND_FROM=

# Where briefs should be delivered. Comma-separated for multiple recipients.
RESEND_TO=hello@luciddesigns.com.au
